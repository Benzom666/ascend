# ============================================
# LESOCIETY API - ENVIRONMENT CONFIGURATION
# ============================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in all required values
# 3. NEVER commit .env to git
# ============================================

# --------------------------------------------
# MongoDB Configuration (REQUIRED)
# --------------------------------------------
# Get from: MongoDB Atlas Dashboard > Database Access
MONGO_USER=your_mongodb_username
MONGO_PASS=your_mongodb_password_here
MONGO_HOST=your-cluster.mongodb.net
DB_NAME=lesociety

# Database Connection Pool (Optional - use defaults)
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=10
MONGO_SERVER_TIMEOUT=30000
MONGO_SOCKET_TIMEOUT=45000

# --------------------------------------------
# Application Configuration (REQUIRED)
# --------------------------------------------
APP_URL=http://localhost:3001
NODE_ENV=development
PORT=3001

# --------------------------------------------
# JWT Secrets (REQUIRED - GENERATE STRONG SECRETS)
# --------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_BASE64_SECRET
JWT_SECRET_TOKEN=REPLACE_WITH_64_BYTE_BASE64_SECRET
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# --------------------------------------------
# CORS Configuration (REQUIRED)
# --------------------------------------------
# Comma-separated list of allowed origins
# Development: http://localhost:3000
# Production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --------------------------------------------
# File Storage - Supabase (REQUIRED for uploads)
# --------------------------------------------
# Get from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_STORAGE_BUCKET=secret-time-uploads

# --------------------------------------------
# Email Configuration (REQUIRED for notifications)
# --------------------------------------------
# Option 1: SendGrid (Recommended)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Option 2: SMTP (Alternative)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your_email@gmail.com
# MAIL_PASS=your_app_specific_password
MAIL_FROM=noreply@lesociety.com

# --------------------------------------------
# Payment Gateway - BucksBus (REQUIRED for payments)
# --------------------------------------------
BUCKSBUS_API_KEY=your_bucksbus_api_key
BUCKSBUS_API_SECRET=your_bucksbus_api_secret
BUCKSBUS_WEBHOOK_SECRET=your_webhook_secret

# --------------------------------------------
# Redis (OPTIONAL - for production caching/sessions)
# --------------------------------------------
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# --------------------------------------------
# Error Monitoring - Sentry (OPTIONAL)
# --------------------------------------------
# Get from: Sentry Dashboard > Settings > Projects
# SENTRY_DSN=https://your-key@sentry.io/project-id
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --------------------------------------------
# Rate Limiting (OPTIONAL - recommended for production)
# --------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --------------------------------------------
# Security (OPTIONAL - recommended for production)
# --------------------------------------------
# BCRYPT_ROUNDS=10
# SESSION_SECRET=your_session_secret_here

# --------------------------------------------
# Logging (OPTIONAL)
# --------------------------------------------
LOG_LEVEL=info
ENABLE_CONSOLE_LOG=true

# ============================================
# Payment Gateway - ELPay (Fiat, No KYC)
# Get from: https://merchant.elpay.online
# ============================================
ELPAY_API_KEY=898403
ELPAY_API_SECRET=c26d600c06354905b560c3d82d32a4af
ELPAY_WEBHOOK_SECRET=your_elpay_webhook_secret
ELPAY_BASE_URL=https://api.elpay.online/int
ELPAY_TEST_MODE=true