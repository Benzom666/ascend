# ============================================
# LESOCIETY FRONTEND - ENVIRONMENT CONFIGURATION
# ============================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Update URLs to match your backend
# 3. NEVER commit .env to git
# ============================================

# --------------------------------------------
# Backend API Configuration (REQUIRED)
# --------------------------------------------
# Development: http://localhost:3001
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# --------------------------------------------
# Environment (REQUIRED)
# --------------------------------------------
# Options: development, staging, production
NEXT_PUBLIC_ENV=development

# --------------------------------------------
# Mobile Development (OPTIONAL)
# --------------------------------------------
# For testing on mobile devices on same network
# Get your IP with: hostname -I | awk '{print $1}'
# Example: NEXT_PUBLIC_DEV_API_URL=http://192.168.1.100:3001
# NEXT_PUBLIC_DEV_API_URL=
# NEXT_PUBLIC_DEV_SOCKET_URL=

# --------------------------------------------
# Feature Flags (OPTIONAL)
# --------------------------------------------
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
# NEXT_PUBLIC_ENABLE_SENTRY=false

# --------------------------------------------
# Analytics (OPTIONAL)
# --------------------------------------------
# NEXT_PUBLIC_GA_TRACKING_ID=
# NEXT_PUBLIC_MIXPANEL_TOKEN=
